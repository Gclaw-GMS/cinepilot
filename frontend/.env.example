# CinePilot Environment Variables
# Copy this file to .env.local and fill in your values

# Database - PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cinepilot?schema=public"

# NextAuth.js Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# AI/ML API (AIML API)
AIML_API_KEY="your-aiml-api-key"
AIML_API_BASE="https://api.aimlapi.com"

# WhatsApp Business API (optional)
WHATSAPP_API_KEY=""
WHATSAPP_BUSINESS_ID=""

# Email (optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@cinepilot.local"

# Weather API (optional)
OPENWEATHERMAP_API_KEY=""

# Storage (optional - Vercel Blob/S3/R2)
BLOB_READ_WRITE_TOKEN=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""

# Redis (optional - for caching/sessions)
REDIS_URL="redis://localhost:6379"
