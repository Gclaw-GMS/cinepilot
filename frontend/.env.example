# =============================================================================
# CinePilot Environment Configuration
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Database (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql://cinepilot:password@localhost:5432/cinepilot

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AI (AIML API - single key unlocks all models) ---
# Sign up at https://aimlapi.com and get your API key
AIML_API_KEY=your-aiml-api-key-here
AIML_BASE_URL=https://api.aimlapi.com/v1

# --- File Storage (S3-compatible: AWS S3 / Cloudflare R2 / MinIO) ---
S3_BUCKET=cinepilot-assets
S3_REGION=ap-south-1
S3_ENDPOINT=                   # Leave blank for AWS, set for R2/MinIO
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# --- Weather (for AI Scheduling Engine) ---
# Free tier at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-key

# --- Auth (NextAuth.js) ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- App ---
NEXT_PUBLIC_APP_NAME=CinePilot
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION=AI-Powered Pre-Production for South Indian Cinema
