'use client'

import { useState } from 'react'
import * as api from '@/lib/api'
import type { ShotList, BudgetEstimate } from '@/lib/types'
import { Card, Button, TextArea, Badge, ProgressBar } from '@/lib/components'

export default function AIToolsPage() {
  const [activeTab, setActiveTab] = useState<'analyze' | 'shots' | 'budget' | 'schedule' | 'real'>('analyze')
  const [loading, setLoading] = useState(false)
  const [result, setResult] = useState<any>(null)
  const [sceneDescription, setSceneDescription] = useState('')
  const [scriptContent, setScriptContent] = useState('')
  const [aiProvider, setAiProvider] = useState<'openai' | 'claude'>('openai')

  const tools = [
    { id: 'analyze', label: 'Script Analysis', icon: '📝', description: 'AI-powered script breakdown' },
    { id: 'real', label: 'Real AI', icon: '🤖', description: 'GPT-4/Claude analysis' },
    { id: 'shots', label: 'Shot Generator', icon: '🎥', description: 'Generate shot lists' },
    { id: 'budget', label: 'Budget Estimate', icon: '💰', description: 'AI budget estimation' },
    { id: 'schedule', label: 'Schedule Optimize', icon: '📅', description: 'Optimize shooting schedule' },
  ]

  const analyzeScript = async () => {
    setLoading(true)
    try {
      // Demo result - API not connected yet
      setResult({
        total_scenes: 45,
        total_locations: 12,
        total_characters: 8,
        estimated_shooting_days: 25,
        estimated_budget: 3000000,
        tags: ['romance', 'thriller', 'family', 'emotional'],
        safety_warnings: ['stunt scene in scene 23', 'fire effects in scene 31'],
        cultural_notes: ['festival scene', 'temple setting'],
      })
    }
    setLoading(false)
    }
  }

  const analyzeRealAI = async () => {
    if (!scriptContent.trim()) {
      alert('Please enter script content for real AI analysis')
      return
    }
    setLoading(true)
    try {
      const response = await api.aiReal.analyze(scriptContent, 'tamil', aiProvider)
      setResult(response)
    } catch (e: any) {
      setResult({ error: e.message || 'Analysis failed', success: false })
    }
    setLoading(false)
  }

  const parseScript = async () => {
    if (!scriptContent.trim()) {
      alert('Please enter script content to parse')
      return
    }
    setLoading(true)
    try {
      const response = await api.scriptParser.parse(scriptContent, 'auto')
      setResult(response)
    } catch (e: any) {
      setResult({ error: e.message || 'Parsing failed', success: false })
    }
    setLoading(false)
  }

  const generateShots = async () => {
    if (!sceneDescription.trim()) return
    setLoading(true)
    try {
      const response = await api.ai.generateShotList(sceneDescription)
      setResult(response)
    } catch (e) {
      setResult({
        shots: [
          { shot_type: 'Wide Shot', description: 'Establish the location', camera: 'Wide', lens: '24mm' },
          { shot_type: 'Medium Shot', description: 'Character introduction', camera: 'Medium', lens: '50mm' },
          { shot_type: 'Close-up', description: 'Emotional beat', camera: 'CU', lens: '85mm' },
          { shot_type: 'Over the Shoulder', description: 'Conversation shot', camera: 'OTS', lens: '50mm' },
        ],
      })
    }
    setLoading(false)
  }

  const estimateBudget = async () => {
    setLoading(true)
    try {
      const response = await api.ai.estimateBudget([], [], 5)
      setResult(response)
    } catch (e) {
      setResult({
        estimated_total: 3250000,
        breakdown: {
          pre_production: 325000,
          production: 2275000,
          post_production: 650000,
          contingency: 325000,
        },
      })
    }
    setLoading(false)
  }

  const generateSchedule = async () => {
    setLoading(true)
    try {
      const response = await api.schedule.generate([], [], 25)
      setResult(response)
    } catch (e) {
      setResult({
        schedule: Array.from({ length: 25 }, (_, i) => ({
          day: i + 1,
          scenes: [],
          location: 'TBD',
          estimated_hours: 10
        }))
      })
    }
    setLoading(false)
  }

  const handleRun = () => {
    switch (activeTab) {
      case 'analyze':
        analyzeScript()
        break
      case 'real':
        analyzeRealAI()
        break
      case 'shots':
        generateShots()
        break
      case 'budget':
        estimateBudget()
        break
      case 'schedule':
        generateSchedule()
        break
    }
  }

  const getTabIcon = (id: string) => tools.find(t => t.id === id)?.icon || '🔧'

  return (
    <div className="p-6">
      <div className="mb-6">
        <h1 className="text-2xl font-bold text-gray-900">🤖 AI Tools</h1>
        <p className="text-gray-600">Power up your pre-production with AI</p>
      </div>

      {/* Tool Selection */}
      <div className="grid grid-cols-2 md:grid-cols-5 gap-3 mb-6">
        {tools.map((tool) => (
          <button
            key={tool.id}
            onClick={() => { setActiveTab(tool.id as any); setResult(null) }}
            className={`p-4 rounded-lg text-left transition-all ${
              activeTab === tool.id
                ? 'bg-blue-50 border-2 border-blue-500 shadow-md'
                : 'bg-white border border-gray-200 hover:border-gray-300'
            }`}
          >
            <span className="text-2xl block mb-2">{tool.icon}</span>
            <h3 className="font-semibold text-gray-800 text-sm">{tool.label}</h3>
            <p className="text-xs text-gray-500 mt-1">{tool.description}</p>
          </button>
        ))}
      </div>

      {/* Input Section */}
      <Card className="mb-6">
        {activeTab === 'analyze' || activeTab === 'real' ? (
          <>
            <label className="block text-sm font-medium text-gray-700 mb-2">
              Script Content {activeTab === 'real' && <span className="text-blue-600">(for Real AI)</span>}
            </label>
            <textarea
              value={scriptContent}
              onChange={(e) => setScriptContent(e.target.value)}
              placeholder="Paste your script here or enter scene descriptions..."
              className="w-full h-40 p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            />
            {activeTab === 'real' && (
              <div className="mt-3 flex items-center gap-4">
                <label className="text-sm font-medium text-gray-700">AI Provider:</label>
                <select
                  value={aiProvider}
                  onChange={(e) => setAiProvider(e.target.value as any)}
                  className="border border-gray-300 rounded px-3 py-1"
                >
                  <option value="openai">OpenAI GPT-4</option>
                  <option value="claude">Claude 3 Opus</option>
                </select>
                <span className="text-xs text-gray-500">(Requires API key in backend)</span>
              </div>
            )}
            <div className="mt-3 flex gap-2">
              <Button onClick={handleRun} loading={loading}>
                {activeTab === 'real' ? '🤖 Run Real AI Analysis' : '📊 Analyze Script'}
              </Button>
              {activeTab === 'analyze' && (
                <Button variant="secondary" onClick={parseScript} loading={loading}>
                  📄 Parse Script Structure
                </Button>
              )}
            </div>
          </>
        ) : activeTab === 'shots' ? (
          <>
            <label className="block text-sm font-medium text-gray-700 mb-2">Scene Description</label>
            <textarea
              value={sceneDescription}
              onChange={(e) => setSceneDescription(e.target.value)}
              placeholder="A romantic conversation between two leads at a busy market..."
              className="w-full h-32 p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
            />
            <Button className="mt-3" onClick={handleRun} loading={loading}>
              🎬 Generate Shot List
            </Button>
          </>
        ) : (
          <div className="text-center py-4">
            <p className="text-gray-500 mb-3">Use default project data for estimation</p>
            <Button onClick={handleRun} loading={loading}>
              {activeTab === 'budget' ? '💰 Estimate Budget' : '📅 Generate Schedule'}
            </Button>
          </div>
        )}
      </Card>

      {/* Results Section */}
      {loading && (
        <Card className="mb-6">
          <div className="text-center py-8">
            <div className="text-3xl mb-3">⚡</div>
            <p className="text-gray-600">AI is thinking...</p>
            <ProgressBar value={60} />
          </div>
        </Card>
      )}

      {result && !loading && (
        <Card>
          <h2 className="text-lg font-semibold text-gray-900 mb-4">📊 Results</h2>
          
          {result.error && (
            <div className="bg-red-50 border border-red-200 rounded-lg p-4">
              <p className="text-red-800">❌ {result.error}</p>
              {result.success === false && result.provider && (
                <p className="text-red-600 text-sm mt-2">
                  Provider: {result.provider} | Model: {result.model}
                </p>
              )}
            </div>
          )}

          {result.analysis && !result.error && (
            <div className="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
              <div className="flex items-center gap-2 mb-2">
                <Badge variant="info">{result.provider?.toUpperCase()}</Badge>
                <Badge variant="default">{result.model}</Badge>
              </div>
              <pre className="whitespace-pre-wrap text-sm text-gray-700 max-h-96 overflow-auto">
                {typeof result.analysis === 'string' ? result.analysis : JSON.stringify(result.analysis, null, 2)}
              </pre>
            </div>
          )}

          {result.summary && (
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
              <div className="bg-gray-50 rounded-lg p-3 text-center">
                <p className="text-2xl font-bold text-blue-600">{result.summary.total_scenes}</p>
                <p className="text-sm text-gray-600">Scenes</p>
              </div>
              <div className="bg-gray-50 rounded-lg p-3 text-center">
                <p className="text-2xl font-bold text-green-600">{result.summary.total_characters}</p>
                <p className="text-sm text-gray-600">Characters</p>
              </div>
              <div className="bg-gray-50 rounded-lg p-3 text-center">
                <p className="text-2xl font-bold text-purple-600">{result.summary.total_locations}</p>
                <p className="text-sm text-gray-600">Locations</p>
              </div>
              <div className="bg-gray-50 rounded-lg p-3 text-center">
                <p className="text-2xl font-bold text-orange-600">{result.summary.int_scenes}/{result.summary.ext_scenes}</p>
                <p className="text-sm text-gray-600">INT / EXT</p>
              </div>
            </div>
          )}

          {result.scenes && Array.isArray(result.scenes) && (
            <div className="space-y-3 mb-4">
              <h3 className="font-medium text-gray-800">Scenes Found: {result.scenes.length}</h3>
              {result.scenes.slice(0, 10).map((scene: any, i: number) => (
                <div key={i} className="bg-gray-50 rounded-lg p-3">
                  <p className="font-medium text-gray-800">{scene.heading}</p>
                  <p className="text-sm text-gray-600 mt-1">{scene.description?.slice(0, 100)}...</p>
                  <div className="flex gap-2 mt-2">
                    <Badge variant={scene.int_ext === 'INT' ? 'info' : 'success'}>{scene.int_ext}</Badge>
                    <Badge variant="warning">{scene.time_of_day}</Badge>
                    {scene.location && <Badge>{scene.location}</Badge>}
                  </div>
                </div>
              ))}
              {result.scenes.length > 10 && (
                <p className="text-sm text-gray-500 text-center">...and {result.scenes.length - 10} more scenes</p>
              )}
            </div>
          )}

          {result.shots && (
            <div className="space-y-3 mb-4">
              <h3 className="font-medium text-gray-800">Shot List</h3>
              {result.shots.map((shot: any, i: number) => (
                <div key={i} className="bg-gray-50 rounded-lg p-3 flex justify-between items-center">
                  <div>
                    <p className="font-medium text-gray-800">{shot.shot_type}</p>
                    <p className="text-sm text-gray-600">{shot.description}</p>
                  </div>
                  <div className="text-right text-sm text-gray-500">
                    <p>{shot.camera}</p>
                    <p>{shot.lens}</p>
                  </div>
                </div>
              ))}
            </div>
          )}

          {result.estimated_total && (
            <div>
              <h3 className="font-medium text-gray-800 mb-3">Budget Breakdown</h3>
              <div className="space-y-2">
                {Object.entries(result.breakdown || {}).map(([key, value]: [string, any]) => (
                  <div key={key} className="flex justify-between items-center">
                    <span className="text-gray-600 capitalize">{key.replace('_', ' ')}</span>
                    <span className="font-medium">₹{((value as number) / 100000).toFixed(1)}L</span>
                  </div>
                ))}
                <div className="border-t pt-2 flex justify-between font-bold">
                  <span>Total</span>
                  <span className="text-blue-600">₹{(result.estimated_total / 100000).toFixed(1)}L</span>
                </div>
              </div>
            </div>
          )}

          {result.schedule && (
            <div>
              <h3 className="font-medium text-gray-800 mb-3">Shooting Schedule</h3>
              <div className="grid grid-cols-5 md:grid-cols-10 gap-2">
                {result.schedule.map((day: any, i: number) => (
                  <div key={i} className="bg-blue-50 rounded p-2 text-center">
                    <p className="font-bold text-blue-600">D{day.day}</p>
                    <p className="text-xs text-gray-600 truncate">{day.location || 'TBD'}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {result.tags && Array.isArray(result.tags) && (
            <div className="mt-4">
              <h3 className="font-medium text-gray-800 mb-2">Tags</h3>
              <div className="flex flex-wrap gap-2">
                {result.tags.map((tag: string, i: number) => (
                  <Badge key={i} variant={['romance', 'love'].includes(tag) ? 'danger' : 
                    ['action', 'thriller'].includes(tag) ? 'danger' : 'info'}>
                    {tag}
                  </Badge>
                ))}
              </div>
            </div>
          )}
        </Card>
      )}
    </div>
  )
}
