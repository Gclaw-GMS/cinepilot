'use client'

import { useState, useEffect, useCallback } from 'react'
import Link from 'next/link'
import { 
  FileText, 
  Download, 
  Calendar, 
  DollarSign, 
  Users, 
  Clapperboard,
  Shield,
  Loader2,
  RefreshCw,
  CheckCircle,
  Clock,
  AlertCircle,
  BarChart3,
  Printer,
  Sparkles,
  ChevronRight
} from 'lucide-react'
import {
  BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, PieChart, Pie, Cell
} from 'recharts'

interface Report {
  id: string
  name: string
  description: string
  icon: string
  format: string
  lastGenerated: string | null
}

interface ProductionData {
  project_name: string
  total_scenes: number
  completed_scenes: number
  shooting_days: number
  remaining_days: number
  budget_spent: number
  budget_total: number
  crew_count: number
  cast_count: number
  locations: number
}

const REPORT_CATEGORIES = [
  {
    title: 'Production Reports',
    reports: [
      { id: 'production-summary', name: 'Production Summary', description: 'Overall project status with key metrics', icon: '📊', format: 'PDF' },
      { id: 'daily-report', name: 'Daily Report', description: 'Daily progress breakdown with scenes shot', icon: '📅', format: 'PDF' },
      { id: 'schedule-report', name: 'Schedule Report', description: 'Timeline analysis and milestone tracking', icon: '🎬', format: 'PDF' },
    ]
  },
  {
    title: 'Financial Reports',
    reports: [
      { id: 'budget-report', name: 'Budget Report', description: 'Financial overview and spending analysis', icon: '💰', format: 'PDF' },
    ]
  },
  {
    title: 'Team Reports',
    reports: [
      { id: 'crew-list', name: 'Crew List', description: 'Complete crew directory with contact details', icon: '👥', format: 'CSV' },
    ]
  },
  {
    title: 'Technical Reports',
    reports: [
      { id: 'shot-list', name: 'Shot List', description: 'Complete shot breakdown with technical details', icon: '🎞️', format: 'CSV' },
      { id: 'equipment-list', name: 'Equipment List', description: 'All rented equipment with return dates', icon: '🎥', format: 'CSV' },
    ]
  },
  {
    title: 'Compliance',
    reports: [
      { id: 'censor-prediction', name: 'CBFC Certificate', description: 'Content sensitivity analysis and rating prediction', icon: '🛡️', format: 'PDF', href: '/reports' },
    ]
  }
]

const DEMO_PRODUCTION_DATA: ProductionData = {
  project_name: 'Kaadhal Enbadhu',
  total_scenes: 52,
  completed_scenes: 28,
  shooting_days: 12,
  remaining_days: 8,
  budget_spent: 4500000,
  budget_total: 8000000,
  crew_count: 35,
  cast_count: 12,
  locations: 8,
}

const DEMO_DAILY_STATS = [
  { date: 'Feb 14', scenes: 5, pages: 3.2, budget: 85000 },
  { date: 'Feb 13', scenes: 4, pages: 2.8, budget: 72000 },
  { date: 'Feb 12', scenes: 6, pages: 4.1, budget: 95000 },
  { date: 'Feb 11', scenes: 3, pages: 2.0, budget: 65000 },
  { date: 'Feb 10', scenes: 5, pages: 3.5, budget: 88000 },
]

const BUDGET_BREAKDOWN = [
  { name: 'Pre-Production', value: 800000, color: '#6366f1' },
  { name: 'Production', value: 3200000, color: '#8b5cf6' },
  { name: 'Post-Production', value: 500000, color: '#a855f7' },
]

export default function ReportsPage() {
  const [loading, setLoading] = useState(true)
  const [generatingReport, setGeneratingReport] = useState<string | null>(null)
  const [generatedReports, setGeneratedReports] = useState<Record<string, string>>({})
  const [isDemoMode, setIsDemoMode] = useState(true)
  const [productionData, setProductionData] = useState<ProductionData | null>(null)

  const fetchReports = useCallback(async () => {
    setLoading(true)
    try {
      const res = await fetch('/api/reports')
      const data = await res.json()
      if (data.reports) {
        setIsDemoMode(data.isDemoMode === true)
      }
      // Load demo production data
      setProductionData(DEMO_PRODUCTION_DATA)
    } catch (err) {
      console.error('Failed to fetch reports:', err)
    } finally {
      setLoading(false)
    }
  }, [])

  useEffect(() => {
    fetchReports()
  }, [fetchReports])

  const handleGenerateReport = async (reportId: string) => {
    setGeneratingReport(reportId)
    try {
      const res = await fetch(`/api/reports?id=${reportId}&action=generate`)
      const data = await res.json()
      if (data.success) {
        setGeneratedReports(prev => ({
          ...prev,
          [reportId]: data.generated_at
        }))
      }
    } catch (err) {
      console.error('Failed to generate report:', err)
    } finally {
      setGeneratingReport(null)
    }
  }

  const formatDate = (dateString: string) => {
    return new Date(dateString).toLocaleDateString('en-GB', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    })
  }

  const formatCurrency = (amount: number) => {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      maximumFractionDigits: 0
    }).format(amount)
  }

  if (loading) {
    return (
      <div className="min-h-screen bg-slate-950 text-slate-100 p-6 flex items-center justify-center">
        <div className="flex items-center gap-3 text-slate-400">
          <Loader2 className="w-5 h-5 animate-spin" />
          <span>Loading reports...</span>
        </div>
      </div>
    )
  }

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100 p-6">
      {/* Header */}
      <div className="flex justify-between items-start mb-8">
        <div>
          <div className="flex items-center gap-3">
            <div className="p-2 bg-gradient-to-br from-indigo-600 to-purple-700 rounded-lg">
              <FileText className="w-6 h-6 text-white" />
            </div>
            <div>
              <h1 className="text-2xl font-bold">Reports Center</h1>
              <p className="text-slate-500 text-sm mt-0.5">Generate and download production reports</p>
            </div>
          </div>
        </div>
        <div className="flex items-center gap-3">
          {isDemoMode && (
            <span className="px-3 py-1 bg-amber-500/20 text-amber-400 text-xs rounded-full font-medium">
              Demo Mode
            </span>
          )}
          <button 
            onClick={fetchReports}
            className="flex items-center gap-2 px-4 py-2 bg-slate-800 hover:bg-slate-700 rounded-lg font-medium text-sm transition-colors"
          >
            <RefreshCw className="w-4 h-4" />
            Refresh
          </button>
        </div>
      </div>

      {/* Quick Stats */}
      {productionData && (
        <div className="grid grid-cols-4 gap-4 mb-8">
          <div className="bg-slate-900 border border-slate-800 rounded-xl p-5">
            <div className="flex items-center gap-3 mb-3">
              <div className="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center">
                <Clapperboard className="w-5 h-5 text-blue-400" />
              </div>
              <span className="text-sm text-slate-400">Progress</span>
            </div>
            <p className="text-2xl font-bold text-white">
              {productionData.completed_scenes}/{productionData.total_scenes}
            </p>
            <p className="text-xs text-slate-500 mt-1">Scenes Completed</p>
          </div>

          <div className="bg-slate-900 border border-slate-800 rounded-xl p-5">
            <div className="flex items-center gap-3 mb-3">
              <div className="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
                <Calendar className="w-5 h-5 text-green-400" />
              </div>
              <span className="text-sm text-slate-400">Schedule</span>
            </div>
            <p className="text-2xl font-bold text-white">
              {productionData.shooting_days} <span className="text-sm font-normal text-slate-500">/ {productionData.shooting_days + productionData.remaining_days}</span>
            </p>
            <p className="text-xs text-slate-500 mt-1">Shooting Days</p>
          </div>

          <div className="bg-slate-900 border border-slate-800 rounded-xl p-5">
            <div className="flex items-center gap-3 mb-3">
              <div className="w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center">
                <DollarSign className="w-5 h-5 text-purple-400" />
              </div>
              <span className="text-sm text-slate-400">Budget</span>
            </div>
            <p className="text-2xl font-bold text-white">
              {Math.round((productionData.budget_spent / productionData.budget_total) * 100)}%
            </p>
            <p className="text-xs text-slate-500 mt-1">{formatCurrency(productionData.budget_spent)} spent</p>
          </div>

          <div className="bg-slate-900 border border-slate-800 rounded-xl p-5">
            <div className="flex items-center gap-3 mb-3">
              <div className="w-10 h-10 bg-amber-500/20 rounded-lg flex items-center justify-center">
                <Users className="w-5 h-5 text-amber-400" />
              </div>
              <span className="text-sm text-slate-400">Team</span>
            </div>
            <p className="text-2xl font-bold text-white">
              {productionData.crew_count + productionData.cast_count}
            </p>
            <p className="text-xs text-slate-500 mt-1">{productionData.crew_count} crew + {productionData.cast_count} cast</p>
          </div>
        </div>
      )}

      {/* Charts Row */}
      <div className="grid grid-cols-2 gap-6 mb-8">
        {/* Daily Progress Chart */}
        <div className="bg-slate-900 border border-slate-800 rounded-xl p-6">
          <h3 className="font-semibold mb-4 text-slate-300 flex items-center gap-2">
            <BarChart3 className="w-5 h-5 text-indigo-400" />
            Daily Progress (Last 5 Days)
          </h3>
          <div className="h-64">
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={DEMO_DAILY_STATS}>
                <CartesianGrid strokeDasharray="3 3" stroke="#334155" />
                <XAxis dataKey="date" stroke="#94a3b8" fontSize={12} />
                <YAxis stroke="#94a3b8" fontSize={12} />
                <Tooltip 
                  contentStyle={{ backgroundColor: '#1e293b', border: 'none', borderRadius: '8px' }}
                  labelStyle={{ color: '#e2e8f0' }}
                />
                <Bar dataKey="scenes" fill="#6366f1" radius={[4, 4, 0, 0]} name="Scenes" />
              </BarChart>
            </ResponsiveContainer>
          </div>
        </div>

        {/* Budget Breakdown */}
        <div className="bg-slate-900 border border-slate-800 rounded-xl p-6">
          <h3 className="font-semibold mb-4 text-slate-300 flex items-center gap-2">
            <DollarSign className="w-5 h-5 text-purple-400" />
            Budget Breakdown
          </h3>
          <div className="h-64 flex items-center">
            <ResponsiveContainer width="100%" height="100%">
              <PieChart>
                <Pie
                  data={BUDGET_BREAKDOWN}
                  cx="50%"
                  cy="50%"
                  innerRadius={60}
                  outerRadius={90}
                  paddingAngle={3}
                  dataKey="value"
                  label={({ name, percent }) => `${name} ${(percent * 100).toFixed(0)}%`}
                  labelLine={false}
                >
                  {BUDGET_BREAKDOWN.map((entry, index) => (
                    <Cell key={`cell-${index}`} fill={entry.color} />
                  ))}
                </Pie>
                <Tooltip 
                  contentStyle={{ backgroundColor: '#1e293b', border: 'none', borderRadius: '8px' }}
                  formatter={(value: number) => formatCurrency(value)}
                />
              </PieChart>
            </ResponsiveContainer>
          </div>
        </div>
      </div>

      {/* Reports Grid */}
      <div className="space-y-8">
        {REPORT_CATEGORIES.map(category => (
          <div key={category.title}>
            <h3 className="text-lg font-semibold text-white mb-4 flex items-center gap-2">
              {category.title === 'Production Reports' && <BarChart3 className="w-5 h-5 text-indigo-400" />}
              {category.title === 'Financial Reports' && <DollarSign className="w-5 h-5 text-purple-400" />}
              {category.title === 'Team Reports' && <Users className="w-5 h-5 text-amber-400" />}
              {category.title === 'Technical Reports' && <Clapperboard className="w-5 h-5 text-blue-400" />}
              {category.title === 'Compliance' && <Shield className="w-5 h-5 text-red-400" />}
              {category.title}
            </h3>
            <div className="grid grid-cols--cols-2 lg:grid-cols-3 gap-4">
             1 md:grid {category.reports.map(report => {
                const isGenerated = generatedReports[report.id]
                const isGenerating = generatingReport === report.id
                const isCensorReport = report.id === 'censor-prediction'
                
                return (
                  <div 
                    key={report.id} 
                    className={`bg-slate-900 border rounded-xl p-5 hover:border-slate-700 transition-colors ${
                      isCensorReport ? 'border-red-500/30 hover:border-red-500/50' : 'border-slate-800'
                    }`}
                  >
                    <div className="flex items-start justify-between mb-3">
                      <div className="flex items-center gap-3">
                        <span className="text-2xl">{report.icon}</span>
                        <div>
                          <h4 className="font-medium text-white">{report.name}</h4>
                          <p className="text-xs text-slate-500">{report.format}</p>
                        </div>
                      </div>
                    </div>
                    <p className="text-sm text-slate-400 mb-4">{report.description}</p>
                    
                    {isGenerated && (
                      <div className="flex items-center gap-2 text-xs text-green-400 mb-3">
                        <CheckCircle className="w-3 h-3" />
                        Generated {formatDate(isGenerated)}
                      </div>
                    )}

                    <div className="flex gap-2">
                      {isCensorReport ? (
                        <Link 
                          href="/censor"
                          className="flex-1 flex items-center justify-center gap-2 px-4 py-2 bg-red-600/20 hover:bg-red-600/30 text-red-400 rounded-lg text-sm font-medium transition-colors"
                        >
                          <Shield className="w-4 h-4" />
                          Open
                          <ChevronRight className="w-4 h-4" />
                        </Link>
                      ) : (
                        <>
                          <button
                            onClick={() => handleGenerateReport(report.id)}
                            disabled={isGenerating}
                            className="flex-1 flex items-center justify-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 disabled:opacity-50 rounded-lg text-sm font-medium transition-colors"
                          >
                            {isGenerating ? (
                              <>
                                <Loader2 className="w-4 h-4 animate-spin" />
                                Generating...
                              </>
                            ) : (
                              <>
                                <Sparkles className="w-4 h-4" />
                                Generate
                              </>
                            )}
                          </button>
                          <button 
                            className="px-4 py-2 bg-slate-800 hover:bg-slate-700 rounded-lg text-sm font-medium transition-colors"
                            disabled={!isGenerated}
                          >
                            <Download className="w-4 h-4" />
                          </button>
                        </>
                      )}
                    </div>
                  </div>
                )
              })}
            </div>
          </div>
        ))}
      </div>

      {/* Recent Activity */}
      <div className="mt-8 bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h3 className="font-semibold mb-4 text-slate-300 flex items-center gap-2">
          <Clock className="w-5 h-5 text-slate-400" />
          Recently Generated Reports
        </h3>
        <div className="space-y-3">
          {Object.keys(generatedReports).length === 0 ? (
            <p className="text-sm text-slate-500 text-center py-4">
              No reports generated yet. Click "Generate" to create your first report.
            </p>
          ) : (
            Object.entries(generatedReports).map(([id, timestamp]) => (
              <div key={id} className="flex items-center justify-between py-2 border-b border-slate-800 last:border-0">
                <div className="flex items-center gap-3">
                  <CheckCircle className="w-4 h-4 text-green-400" />
                  <span className="text-sm text-slate-300">
                    {REPORT_CATEGORIES.flatMap(c => c.reports).find(r => r.id === id)?.name || id}
                  </span>
                </div>
                <span className="text-xs text-slate-500">{formatDate(timestamp)}</span>
              </div>
            ))
          )}
        </div>
      </div>
    </div>
  )
}
